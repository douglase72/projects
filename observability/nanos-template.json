{
  "index_patterns": ["filebeat-*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date_nanos" },
        "mdc.traceId": { "type": "keyword" },
        "message": { "type": "text" },
        "log.level": { "type": "keyword" },
        "service.name": { "type": "keyword" },
        "container.name": { "type": "keyword" },
        "error.stack_trace": { "type": "text" }        
      }
    }
  },
  "priority": 500
}
