{
  "compilerOptions": {
    /* Base Options */
    "target": "ES2022", // Compile to modern JavaScript
    "module": "NodeNext", // Use the modern Node.js module system
    "moduleResolution": "NodeNext",
    "esModuleInterop": true, // Improves compatibility between CommonJS and ES Modules
    "forceConsistentCasingInFileNames": true,

    /* Output */
    "outDir": "./dist", // Where to output compiled JavaScript
    "rootDir": "./src", // Where your TypeScript source code is

    /* Strictness */
    "strict": true, // Enable all strict type-checking options
    "skipLibCheck": true // Skip type checking of all declaration files (*.d.ts)
  },
  "include": ["src/**/*"] // Tells 'tsc' to only look in the 'src' folder
}