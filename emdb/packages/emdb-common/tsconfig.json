{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "verbatimModuleSyntax": true,

    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true, 
    "declarationMap": true,
    "sourceMap": true,

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,

    "composite": true 
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
